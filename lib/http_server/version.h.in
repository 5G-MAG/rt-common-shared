#define HTTPXPP_SERVER_VERSION @HTTPX_SERVER_VERSION@
#define HTTPXPP_SERVER_VERSION_MAJOR @HTTPX_SERVER_MAJOR@
#define HTTPXPP_SERVER_VERSION_MINOR @HTTPX_SERVER_MINOR@
#define HTTPXPP_SERVER_VERSION_MICRO @HTTPX_SERVER_MICRO@
#define HTTPX_SERVER_VERSION_LT(MAJOR, MICRO, MINOR) (HTTPX_SERVER_VERSION_MAJOR < MAJOR || (HTTPX_SERVER_VERSION_MAJOR == MAJOR && HTTPX_SERVER_VERSION_MINOR < MINOR) || (HTTPX_SERVER_VERSION_MAJOR == MAJOR && HTTPX_SERVER_VERSION_MINOR == MINOR && HTTPX_SERVER_VERSION_MICRO < MICRO))
#define HTTPX_SERVER_VERSION_GT(MAJOR, MICRO, MINOR) (HTTPX_SERVER_VERSION_MAJOR > MAJOR || (HTTPX_SERVER_VERSION_MAJOR == MAJOR && HTTPX_SERVER_VERSION_MINOR > MINOR) || (HTTPX_SERVER_VERSION_MAJOR == MAJOR && HTTPX_SERVER_VERSION_MINOR == MINOR && HTTPX_SERVER_VERSION_MICRO > MICRO))
#define HTTPX_SERVER_VERSION_EQ(MAJOR, MICRO, MINOR) (HTTPX_SERVER_VERSION_MAJOR == MAJOR && HTTPX_SERVER_VERSION_MINOR == MINOR && HTTPX_SERVER_VERSION_MICRO == MICRO)
#define HTTPX_SERVER_VERSION_LE(MAJOR, MICRO, MINOR) (HTTPX_SERVER_VERSION_EQ(MAJOR, MICRO, MINOR) || HTTPX_SERVER_VERSION_LT(MAJOR, MICRO, MINOR))
#define HTTPX_SERVER_VERSION_GE(MAJOR, MICRO, MINOR) (HTTPX_SERVER_VERSION_EQ(MAJOR, MICRO, MINOR) || HTTPX_SERVER_VERSION_GT(MAJOR, MICRO, MINOR))

/* vim:ts=8:sts=4:sw=4:expandtab:
 */

#endif // ifndef _RT_COMMON_HTTP_X_SERVER_VERSION_H_
