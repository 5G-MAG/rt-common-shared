#define LIBRTSDP_VERSION @LIBRTSDP_VERSION@
#define LIBRTSDP_VERSION_MAJOR @LIBRTSDP_MAJOR@
#define LIBRTSDP_VERSION_MINOR @LIBRTSDP_MINOR@
#define LIBRTSDP_VERSION_MICRO @LIBRTSDP_MICRO@
#define LIBRTSDP_VERSION_LT(MAJOR, MICRO, MINOR) (LIBRTSDP_VERSION_MAJOR < MAJOR || (LIBRTSDP_VERSION_MAJOR == MAJOR && LIBRTSDP_VERSION_MINOR < MINOR) || (LIBRTSDP_VERSION_MAJOR == MAJOR && LIBRTSDP_VERSION_MINOR == MINOR && LIBRTSDP_VERSION_MICRO < MICRO))
#define LIBRTSDP_VERSION_GT(MAJOR, MICRO, MINOR) (LIBRTSDP_VERSION_MAJOR > MAJOR || (LIBRTSDP_VERSION_MAJOR == MAJOR && LIBRTSDP_VERSION_MINOR > MINOR) || (LIBRTSDP_VERSION_MAJOR == MAJOR && LIBRTSDP_VERSION_MINOR == MINOR && LIBRTSDP_VERSION_MICRO > MICRO))
#define LIBRTSDP_VERSION_EQ(MAJOR, MICRO, MINOR) (LIBRTSDP_VERSION_MAJOR == MAJOR && LIBRTSDP_VERSION_MINOR == MINOR && LIBRTSDP_VERSION_MICRO == MICRO)
#define LIBRTSDP_VERSION_LE(MAJOR, MICRO, MINOR) (LIBRTSDP_VERSION_EQ(MAJOR, MICRO, MINOR) || LIBRTSDP_VERSION_LT(MAJOR, MICRO, MINOR))
#define LIBRTSDP_VERSION_GE(MAJOR, MICRO, MINOR) (LIBRTSDP_VERSION_EQ(MAJOR, MICRO, MINOR) || LIBRTSDP_VERSION_GT(MAJOR, MICRO, MINOR))

/* vim:ts=8:sts=4:sw=4:expandtab:
 */

#endif // ifndef _RT_COMMON_SDP_LIBRARY_VERSION_H_
